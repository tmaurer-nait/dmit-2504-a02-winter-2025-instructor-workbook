    {
      "id": "m2HgSEZqltLQCSWzPzFBx",
      "type": "text",
      "x": 1559.364689093918,
      "y": 1154.230821434272,
      "width": 470.79962158203125,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0p",
      "roundness": null,
      "seed": 659015618,
      "version": 154,
      "versionNonce": 274885214,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772472475968,
      "link": null,
      "locked": false,
      "text": "You don't want unauthenticated users accessing\nparts of your app that require authentication",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "You don't want unauthenticated users accessing\nparts of your app that require authentication",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_7mZrttMkjNquCxxSGoYR",
      "type": "text",
      "x": 1556.1947507491132,
      "y": 1248.4078728573604,
      "width": 476.5596618652344,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0q",
      "roundness": null,
      "seed": 1177230210,
      "version": 213,
      "versionNonce": 1805741726,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772472475968,
      "link": null,
      "locked": false,
      "text": "The backend does the real security,\nif they slip through to an unprotected route\nit'll just be a UX issue.\n(Broken pages, placeholder data, empty, crashes)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The backend does the real security,\nif they slip through to an unprotected route\nit'll just be a UX issue.\n(Broken pages, placeholder data, empty, crashes)",
      "autoResize": true,
      "lineHeight": 1.25
    },
