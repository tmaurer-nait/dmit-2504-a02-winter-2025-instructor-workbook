    {
      "id": "mQGdW0Xn9zq-sq_Dp-ceV",
      "type": "text",
      "x": -370.3014890808271,
      "y": 887.2853221878675,
      "width": 316.095703125,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 1556561258,
      "version": 135,
      "versionNonce": 141179254,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678069432,
      "link": null,
      "locked": false,
      "text": "you don't want to communicate with real\ndata when running test cases. Instead\nyou mock those connections.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "you don't want to communicate with real\ndata when running test cases. Instead\nyou mock those connections.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ozlrp1VI_uvzCQxgz_q8T",
      "type": "text",
      "x": -327.02408849305647,
      "y": 973.7263771436047,
      "width": 175.8558349609375,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "az",
      "roundness": null,
      "seed": 227085930,
      "version": 99,
      "versionNonce": 827072758,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678089053,
      "link": null,
      "locked": false,
      "text": "MOCK:\n- api calls\n- third party packages\n- db connections",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MOCK:\n- api calls\n- third party packages\n- db connections",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DHKfwqdDTDcHeRoEYKLKC",
      "type": "text",
      "x": -185.22696512531127,
      "y": 1256.5669982625734,
