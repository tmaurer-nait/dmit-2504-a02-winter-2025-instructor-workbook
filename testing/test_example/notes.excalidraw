      "groupIds": [],
      "frameId": null,
      "index": "b00",
      "roundness": null,
      "seed": 953012650,
      "version": 37,
      "versionNonce": 1459352310,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678187194,
      "link": null,
      "locked": false,
      "text": "Test Driven Development (TDD)",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Test Driven Development (TDD)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nFVsXHpfOy8_6qJrEkhNq",
      "type": "text",
      "x": -115.7917869358431,
      "y": 1317.007859697939,
      "width": 286.059814453125,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b01",
      "roundness": null,
      "seed": 437737782,
      "version": 95,
      "versionNonce": 1150664694,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678243637,
      "link": null,
      "locked": false,
      "text": "1. Write tests\n2. Write Code to Pass Tests",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Write tests\n2. Write Code to Pass Tests",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cclzdxQUh_g7bvuOmS6f5",
      "type": "text",
      "x": -183.4535772639968,
      "y": 1394.4067495248287,
      "width": 601.9796142578125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b03",
      "roundness": null,
      "seed": 1501424118,
      "version": 195,
      "versionNonce": 2114947242,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678452470,
      "link": null,
      "locked": false,
      "text": "Pros:\n- Avoid code breaking issues early on\n- Works as a wireframe for your code\n- FORCES you to think about edge cases and code structure\n- Necessitates tests existing",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n- Avoid code breaking issues early on\n- Works as a wireframe for your code\n- FORCES you to think about edge cases and code structure\n- Necessitates tests existing",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "__OWNHozVvzX3VC-EOlMD",
      "type": "text",
      "x": -185.46319689366874,
      "y": 1559.9775705148159,
      "width": 735.2796020507812,
      "height": 150,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 1051983478,
      "version": 270,
      "versionNonce": 321038198,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678727112,
      "link": null,
      "locked": false,
      "text": "Cons:\n- Takes time (you have no choice but to write tests)\n- Management sometimes doesn't see the point\n- Can restrict experimentation\n- Not good for prototypes or code that you expect to throw out anyways\n- Can be difficult for frontend",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cons:\n- Takes time (you have no choice but to write tests)\n- Management sometimes doesn't see the point\n- Can restrict experimentation\n- Not good for prototypes or code that you expect to throw out anyways\n- Can be difficult for frontend",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DNZaqbRopltDJm6PIQszK",
      "type": "text",
      "x": 1542.7936981003234,
      "y": 1508.8696389514007,
      "width": 469.36376953125,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b05",
      "roundness": null,
      "seed": 2015494250,
      "version": 103,
      "versionNonce": 1214728566,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678819351,
      "link": null,
      "locked": false,
      "text": "Alternative to Automated Testing\nQA (Quality Assurance)\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Alternative to Automated Testing\nQA (Quality Assurance)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YTKYTUYulXGarPvc31HaZ",
      "type": "text",
      "x": 1407.0785211918662,
      "y": 1620.5529067681175,
      "width": 737.5994873046875,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b06",
      "roundness": null,
      "seed": 75232566,
      "version": 270,
      "versionNonce": 1186507370,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773678945954,
      "link": null,
      "locked": false,
      "text": "Essentially you write a script for a human (maybe AI?) to go through\nand validate functionality.\n\nOften you'll deploy to a test server and have QA go through that.\n\nUsually this is an alternative to E2E/Integration testing not Unit testing.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Essentially you write a script for a human (maybe AI?) to go through\nand validate functionality.\n\nOften you'll deploy to a test server and have QA go through that.\n\nUsually this is an alternative to E2E/Integration testing not Unit testing.",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
